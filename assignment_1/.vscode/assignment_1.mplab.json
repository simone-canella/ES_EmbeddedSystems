{
    "version": "1.9",
    "configurations": [
        {
            "name": "default",
            "id": "conf1",
            "device": "dsPIC33EP512MU810",
            "imagePath": "./out/assignment_1/default.elf",
            "packs": [
                {
                    "name": "dsPIC33E-GM-GP-MC-GU-MU_DFP",
                    "vendor": "Microchip",
                    "version": "1.6.297"
                }
            ],
            "fileSet": "default",
            "toolchain": "default-XC16"
        }
    ],
    "propertyGroups": [
        {
            "name": "default-XC16",
            "type": "toolchain",
            "provider": "microchip.toolchains:xc16@2.10",
            "properties": {
                "compiler.optimization-level": "2",
                "compiler.keep-inline": true
            }
        }
    ],
    "fileSets": [
        {
            "name": "default",
            "files": [
                {
                    "include": "**/*",
                    "exclude": "**/(_build|out|cmake|.vscode)/**/*"
                }
            ]
        }
    ]
}
