# ==========================================
# Doxygen Documentation Protection Filters
# ==========================================
# Ignore intermediate TeX formula logs and temporary code maps
docs/*.tex
docs/*.log
docs/*.aux
docs/*.toc
docs/*.synctex.gz

# NEVER ignore the final HTML website assets
!docs/**/*.html
!docs/**/*.css
!docs/**/*.js
!docs/**/*.png
!docs/**/*.svg
!docs/**/*.jpg
!docs/.nojekyll

# ==========================================
# Miscellaneous and Untracked Files
# ==========================================
tree.txt
.DS_Store
Thumbs.db
